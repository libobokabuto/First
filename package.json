{
  "name": "docket-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "DocKit Monorepo — 全能文档阅读编辑器（手机 + 桌面）",
  "author": "libobokabuto",
  "license": "MIT",
  "scripts": {
    "dev:mobile": "pnpm --filter @docket/mobile dev",
    "dev:desktop": "pnpm --filter @docket/desktop dev",
    "build:shared": "pnpm --filter @docket/shared build",
    "build:mobile": "pnpm --filter @docket/mobile build",
    "build:desktop": "pnpm --filter @docket/desktop build",
    "build": "pnpm build:shared && pnpm build:mobile && pnpm build:desktop",
    "typecheck": "pnpm --recursive typecheck",
    "lint": "pnpm --recursive lint"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.1.0"
}
